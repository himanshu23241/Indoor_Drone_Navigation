    </model>
    <model name="kitchen_counter">
      <static>true</static><pose>-8.5 -3 0.45 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.6 4.0 0.9</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.6 4.0 0.9</size></box></geometry><material><ambient>0.8 0.8 0.8 1</ambient><diffuse>0.8 0.8 0.8 1</diffuse></material></visual>
